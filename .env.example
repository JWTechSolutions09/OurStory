# Copia a .env (no subas .env).
# Cloudflare Pages: mismo proyecto que el build Git → Settings → Environment variables
# (Production y/o Preview segun la rama). Nombres exactos abajo.
#
# Build (scripts/build.mjs) escribe dist/env.js (preview local / fallback).
# En Cloudflare Pages, functions/env.js/index.js sirve /env.js en runtime con
# las mismas variables del proyecto (no dependen del build).
# index.html lee OURBOOK_CONFIG.supabaseUrl y supabaseAnonKey.

# URL del proyecto (Settings → API → Project URL), siempre https://....supabase.co
SUPABASE_URL=https://ptdhbumkpjviuxenbbmr.supabase.co

# Clave anon = JWT largo (Settings → API → anon public), NO uses sb_publishable_... aquí
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NUNCA: sb_secret / service_role en el frontend ni en variables del build estático.
